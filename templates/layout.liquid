
{% assign pageTitle = page.title | default: 'Q&A' %}
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ pageTitle }} - Power Pages Q&A</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/assets/css/site.css" rel="stylesheet">
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
      <div class="container">
        <a class="navbar-brand" href="/">Q&A</a>
        <div>
          <a class="btn btn-light btn-sm" href="/ask">Ask Question</a>
        </div>
      </div>
    </nav>

    <main class="container py-4">
      {% block main %}{% endblock %}
    </main>

    <footer class="border-top py-4 mt-5">
      <div class="container d-flex justify-content-between align-items-center">
        <span class="text-muted">Power Pages Q&A Starter</span>
        <span class="text-muted">{{ now | date: 'yyyy' }}</span>
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/assets/js/site.js"></script>
  </body>
</html>
