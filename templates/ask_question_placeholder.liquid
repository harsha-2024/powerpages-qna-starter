
{% extends 'Layout' %}
{% block main %}
  <h1 class="h4 mb-3">Ask a public question</h1>
  <div class="alert alert-info">
    This starter uses a **Basic Form** for the **pp_question** table. In Design Studio,
    add a form component here. Suggested fields: `pp_title`, `pp_body`, `pp_tags`.
  </div>
  <p>Tips:</p>
  <ul>
    <li>Use clear titles (what, where, when, expected vs actual).</li>
    <li>Add code blocks and error messages in the body.</li>
    <li>Separate tags by commas (e.g., <code>javascript,react</code>).</li>
  </ul>
{% endblock %}
